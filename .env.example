# Copy to .env and fill in. .env is gitignored.

# Dashboard credentials — change these before exposing publicly.
DASH_USER=admin
DASH_PASS=change-me

# Long random hex string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-long-random-hex

# Optional: path to a proxies file (one proxy per line).
# Formats: http://user:pass@host:port  |  host:port:user:pass  |  host:port
# PROXIES_FILE=proxies.txt
